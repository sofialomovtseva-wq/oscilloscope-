            border: 1px solid #00ff00;
        }
        
        .footer {
            margin-top: 50px;
            text-align: right;
            font-size: 14px;
        }
        
        .terminal {
            font-size: 20px;
            line-height: 2;
            margin: 30px 0;
            min-height: 350px;
            font-family: 'Kelly Slab', cursive;
        }
        
        .terminal-line {
            margin: 5px 0;
            white-space: pre-wrap;
        }
        
        .input-container {
            margin-top: 30px;
            font-size: 22px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .terminal-input-wrapper {
            position: relative;
            display: inline-block;
            width: 40px;
            height: 35px;
            background-color: black;
            border: none;
        }
        
        #pageInput {
            position: absolute;
            width: 100%;
            height: 100%;
            background-color: transparent;
            border: none;
            color: transparent;
            font-family: 'Kelly Slab', cursive;
            font-size: 22px;
            text-align: center;
            outline: none;
            z-index: 2;
            cursor: default;
        }
        
        .cursor {
            position: absolute;
            width: 100%;
            height: 100%;
            background-color: #00ff00;
            animation: blink 1s infinite;
            z-index: 1;
        }
        
        .display-char {
            position: absolute;
            width: 100%;
            height: 100%;
            color: black;
            font-family: 'Kelly Slab', cursive;
            font-size: 22px;
            text-align: center;
            line-height: 35px;
            background-color: #00ff00;
            z-index: 3;
            display: none;
        }
        
        @keyframes blink {
            0%, 50% { opacity: 1; }
            51%, 100% { opacity: 0; }
        }
        
        .error-message {
            color: #ff5555;
            margin-top: 10px;
            font-size: 18px;
            display: none;
        }
        
        table {
            border-collapse: collapse;
            width: 100%;
        }

        table, th, td {
            border: 1px solid #00ff00;
        }

        td, th {
            padding: 10px;
        }

        .frame-box {
            border: 2px solid #00ff00;
            padding: 10px;
            box-shadow: 0 0 15px #00ff00;
        }

        .aspect-16-9 {
            position: relative;
            width: 100%;
            padding-top: 56.25%;
        }

        .aspect-16-9 iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: none;
            background: black;
        }

        .caption {
            margin-top: 10px;
            text-align: center;
        }

        .epoch {
            background: rgba(0, 30, 0, 0.5);
            border: 2px solid #00ff00;
            border-radius: 15px;
            padding: 20px 25px;
            margin-bottom: 25px;
            box-shadow: 0 5px 15px rgba(0, 255, 0, 0.1);
            transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
            cursor: pointer;
        }

        .card {
            background: rgba(0, 30, 0, 0.3);
            border: 1px solid #00ff00;
            border-radius: 12px;
            padding: 20px;
            transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
            cursor: pointer;
        }

        .year {
            font-size: 28px;
            font-weight: bold;
            font-family: 'Stalinist One', sans-serif;
            color: #00ff00;
            border-bottom: 2px solid #00ff00;
            display: inline-block;
            margin-bottom: 10px;
            padding-bottom: 5px;
        }

        .inventor {
            background: rgba(0, 255, 0, 0.1);
            border-left: 3px solid #00ff00;
            padding: 8px 15px;
            margin-top: 15px;
            font-family: monospace;
            font-size: 14px;
        }

        .grid-2col {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 25px;
            margin: 40px 0;
        }

        footer {
            margin-top: 50px;
            padding-top: 20px;
            border-top: 1px solid #00ff00;
            text-align: center;
            font-size: 14px;
            color: #00aa00;
        }

        .epoch:hover, .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 20px rgba(0, 255, 0, 0.4);
            border-color: #88ff88;
            background: rgba(0, 50, 0, 0.6);
        }
    </style>
