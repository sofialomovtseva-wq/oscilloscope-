<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>oscilloscope-music - оглавление</title>
    <link href="https://fonts.googleapis.com/css2?family=Kelly+Slab&family=Stalinist+One&display=swap" rel="stylesheet">

    <style>
        body {
            background-color: black;
            color: #00ff00;
            font-family: 'Kelly Slab', cursive;
            margin: 40px;
        }

        h1 {
            font-family: 'Stalinist One', sans-serif;
            color: #00ff00;
            text-align: center;
            font-size: 36px;
        }

        h2 {
            color: #00ff00;
            border-bottom: 1px solid #00ff00;
            border-top: 1px solid #00ff00;
            padding-bottom: 5px;
        }

        a {
            color: #00ff00;
            text-decoration: underline;
        }

        a:hover {
            background-color: #00ff00;
            color: black;
        }

        hr {
            border: 1px solid #00ff00;
        }

        .footer {
            margin-top: 50px;
            text-align: right;
            font-size: 14px;
        }

        .terminal {
            font-size: 20px;
            line-height: 2;
            margin: 30px 0;
            min-height: 350px;
            font-family: 'Kelly Slab', cursive;
        }

        .terminal-line {
            margin: 5px 0;
            white-space: pre-wrap;
        }

        .input-container {
            margin-top: 30px;
            font-size: 22px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .terminal-input-wrapper {
            position: relative;
            display: inline-block;
            width: 40px;
            height: 35px;
            background-color: black;
            border: none;
        }

        #pageInput {
            position: absolute;
            width: 100%;
            height: 100%;
            background-color: transparent;
            border: none;
            color: transparent;
            font-family: 'Kelly Slab', cursive;
            font-size: 22px;
            text-align: center;
            outline: none;
            z-index: 2;
            cursor: default;
        }

        .cursor {
            position: absolute;
            width: 100%;
            height: 100%;
            background-color: #00ff00;
            animation: blink 1s infinite;
            z-index: 1;
        }

        .display-char {
            position: absolute;
            width: 100%;
            height: 100%;
            color: black;
            font-family: 'Kelly Slab', cursive;
            font-size: 22px;
            text-align: center;
            line-height: 35px;
            background-color: #00ff00;
            z-index: 3;
            display: none;
        }

        @keyframes blink {
            0%, 50% { opacity: 1; }
            51%, 100% { opacity: 0; }
        }

        .error-message {
            color: #ff5555;
            margin-top: 10px;
            font-size: 18px;
            display: none;
        }

        table {
        border-collapse: collapse;
            width: 100%;
        }

        table, th, td {
            border: 1px solid #00ff00;
        }

        td, th {
            padding: 10px;
        }

        .frame-box {
            border: 2px solid #00ff00;
            padding: 10px;
            box-shadow: 0 0 15px #00ff00;
        }

        .aspect-16-9 {
            position: relative;
            width: 100%;
            padding-top: 56.25%;
        }

        .aspect-16-9 iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: none;
            background: black;
        }

        .caption {
            margin-top: 10px;
            text-align: center;
        }

        .epoch {
            background: rgba(0, 30, 0, 0.5);
            border: 2px solid #00ff00;
            border-radius: 15px;
            padding: 20px 25px;
            margin-bottom: 25px;
            box-shadow: 0 5px 15px rgba(0, 255, 0, 0.1);
            transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
            cursor: pointer;
        }

        .card {
            background: rgba(0, 30, 0, 0.3);
            border: 1px solid #00ff00;
            border-radius: 12px;
            padding: 20px;
            transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
            cursor: pointer;
        }

        .year {
            font-size: 28px;
            font-weight: bold;
            font-family: 'Stalinist One', sans-serif;
            color: #00ff00;
            border-bottom: 2px solid #00ff00;
            display: inline-block;
            margin-bottom: 10px;
            padding-bottom: 5px;
        }

        .inventor {
            background: rgba(0, 255, 0, 0.1);
            border-left: 3px solid #00ff00;
            padding: 8px 15px;
            margin-top: 15px;
            font-family: monospace;
            font-size: 14px;
        }

        .grid-2col {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 25px;
            margin: 40px 0;
        }

        footer {
            margin-top: 50px;
            padding-top: 20px;
            border-top: 1px solid #00ff00;
            text-align: center;
            font-size: 14px;
            color: #00aa00;
        }

        .epoch:hover, .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 20px rgba(0, 255, 0, 0.4);
            border-color: #88ff88;
            background: rgba(0, 50, 0, 0.6);
        }

            .video-row {
            display: flex;
            justify-content: center;
            gap: 30px;
            flex-wrap: wrap;
            margin: 40px 0;
        }

        .video-card {
            background-color: black;
            border: 5px solid #00ff00;
            border-radius: 10px;
            padding: 15px 15px 15px 15px;
            width: 400px;
            box-shadow: 0 0 15px #00ff00;
            text-align: center;
        }

        .video-caption {
            color: #00ff00;
            font-family: 'Stalinist One', cursive;
            margin-top: 15px;
            font-size: 18px;
            border-top: 1px dashed #00ff00;
            padding-top: 10px;
        }

        .video-card video {
            width: 100%;
            height: auto;
            border-radius: 10px;
            border: 1px solid #00ff00;
        }
    </style>
</head>
<body>
    <h1>OSCILLOSCOPE-MUSIC</h1>

    <hr>

    <div class="caption">
        <p>
        <a href="index.html">[ ГЛАВНАЯ ]</a> |
        <a href="content.html">[ ОГЛАВЛЕНИЕ ]</a> |
        <a href="howork.html">[ КАК РАБОТАЕТ ОСЦИЛЛОГРАФ ]</a> |
        <a href="myexp.html">[ МОЁ ЗНАКОМСТВО ]</a> |
        <a href="history.html">[ ИСТОРИЯ ]</a> |
        <a href="visual.html">[ ВИЗУАЛИЗАТОР ]</a>
        </p>
    </div>

    <hr>

    <div class="terminal" id="terminal"></div>

    <div class="input-container" id="inputContainer" style="display: none;">
        <span>> Введите номер страницы (1-6): [</span>

        <div class="terminal-input-wrapper">
            <input type="text" id="pageInput" maxlength="1">
            <div class="cursor" id="cursor"></div>
            <div class="display-char" id="displayChar"></div>
        </div>

        <span>]</span>
    </div>

    <div class="error-message" id="errorMessage">Ошибка! Введите число от 1 до 6</div>

    <hr>

    <script>

        const lines = [
            "> Загрузка оглавления...",
            "",
            "> [1] ГЛАВНАЯ - index.html",
            "> [2] ОГЛАВЛЕНИЕ - content.html",
            "> [3] КАК РАБОТАЕТ ОСЦИЛОГРАФ - howork.html",
            "> [4] МОЁ ЗНАКОМСТВО - myexp.html",
            "> [5] ИСТОРИЯ - history.html",
            "> [6] ВИЗУАЛИЗАТОР - test.html",
            "",
            "> Система готова."
        ];

        let currentLine = 0;
        let currentChar = 0;
        let isPrinting = true;

        const terminal = document.getElementById('terminal');
        const inputContainer = document.getElementById('inputContainer');
        const pageInput = document.getElementById('pageInput');
        const cursor = document.getElementById('cursor');
        const displayChar = document.getElementById('displayChar');
        const errorMessage = document.getElementById('errorMessage');

        function printNextChar() {
            if (!isPrinting) return;

            if (currentLine >= lines.length) {
                isPrinting = false;
                inputContainer.style.display = 'flex';
                pageInput.focus();
                return;
            }

            if (currentChar === 0) {
                const lineDiv = document.createElement('div');
                lineDiv.className = 'terminal-line';
                lineDiv.id = 'line-' + currentLine;
                terminal.appendChild(lineDiv);
            }

            const lineDiv = document.getElementById('line-' + currentLine);
            const fullLine = lines[currentLine];

            if (currentChar < fullLine.length) {
                lineDiv.textContent += fullLine[currentChar];
                currentChar++;
                const delay = Math.random() * 1 + 3;
                setTimeout(printNextChar, delay);
            } else {
                currentLine++;
                currentChar = 0;
                setTimeout(printNextChar, 200);
            }
        }

        window.onload = function() {
            setTimeout(printNextChar, 300);
        };


        const pages = {
            '1': 'index.html',
            '2': 'content.html',
            '3': 'howork.html',
            '4': 'myexp.html',
            '5': 'types.html',
            '6': 'gonio/index.html'
        };

        pageInput.addEventListener('input', function() {
            const val = this.value;

            if (val.length > 0) {
                displayChar.style.display = 'block';
                displayChar.textContent = val;
                cursor.style.display = 'none';
            } else {
                displayChar.style.display = 'none';
                cursor.style.display = 'block';
            }
        });

        pageInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                const num = this.value;

                if (pages[num]) {
                    window.location.href = pages[num];
                } else if (num.length > 0) {
                    errorMessage.style.display = 'block';
                    this.value = '';
                    displayChar.style.display = 'none';
                    cursor.style.display = 'block';

                    setTimeout(() => {
                        errorMessage.style.display = 'none';
                    }, 2000);
                }
            }
        });

        pageInput.addEventListener('blur', function() {
            if (this.value.length === 0) {
                displayChar.style.display = 'none';
                cursor.style.display = 'block';
            }
        });

        pageInput.addEventListener('keydown', function(e) {
            const key = e.key;
            if (key === 'Backspace' || key === 'Delete' || key === 'Tab' || key === 'Enter' || key.startsWith('Arrow')) {
                return;
            }
            if (!/^[1-6]$/.test(key)) {
                e.preventDefault();
            }
        });

    </script>
</body>
</html>
